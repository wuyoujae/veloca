{
  "name": "veloca",
  "version": "0.4.0",
  "description": "Veloca is an Electron markdown editor inspired by Typora.",
  "main": "dist/backend/main/main.js",
  "type": "module",
  "scripts": {
    "postinstall": "electron-rebuild -f -w better-sqlite3 --dist-url=https://npmmirror.com/mirrors/electron/",
    "dev": "electron-vite dev",
    "build": "tsc --noEmit && electron-vite build",
    "preview": "electron-vite preview",
    "lint": "eslint . --ext .ts,.tsx",
    "test": "node --test app/test/*.test.mjs",
    "typecheck": "tsc --noEmit",
    "verify:renderer-build": "node -e \"require('node:fs').accessSync('dist/frontend/index.html')\"",
    "package:mac": "electron-vite build && electron-builder --mac",
    "package:win": "electron-vite build && electron-builder --win",
    "package:linux": "electron-vite build && electron-builder --linux",
    "package:all": "electron-vite build && electron-builder --mac --win --linux",
    "release:check": "npm run typecheck && npm run test && npm run build && npm run verify:renderer-build",
    "release:patch": "npm run release:check && npm version patch",
    "release:minor": "npm run release:check && npm version minor",
    "release:major": "npm run release:check && npm version major",
    "release:push": "git push origin HEAD --follow-tags"
  },
  "build": {
    "appId": "com.veloca.app",
    "productName": "Veloca",
    "directories": {
      "output": "release"
    },
    "electronDownload": {
      "mirror": "https://npmmirror.com/mirrors/electron/"
    },
    "npmRebuild": false,
    "files": [
      "dist/**/*",
      "resources/**/*",
      {
        "from": "node_modules/call-bind-apply-helpers",
        "to": "node_modules/call-bind-apply-helpers",
        "filter": [
          "**/*"
        ]
      },
      "package.json"
    ],
    "mac": {
      "icon": "resources/icon.icns",
      "category": "public.app-category.productivity",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ]
    },
    "win": {
      "icon": "resources/icon.ico",
      "target": [
        {
          "target": "zip",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "linux": {
      "icon": "resources/icon.png",
      "category": "Office",
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        }
      ]
    }
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.105.1",
    "@tiptap/extension-code-block": "^3.22.4",
    "@tiptap/extension-emoji": "^3.22.4",
    "@tiptap/extension-file-handler": "^3.22.4",
    "@tiptap/extension-highlight": "^3.22.4",
    "@tiptap/extension-image": "^3.22.4",
    "@tiptap/extension-link": "^3.22.4",
    "@tiptap/extension-mathematics": "^3.22.4",
    "@tiptap/extension-placeholder": "^3.22.4",
    "@tiptap/extension-subscript": "^3.22.4",
    "@tiptap/extension-superscript": "^3.22.4",
    "@tiptap/extension-table": "^3.22.4",
    "@tiptap/extension-table-cell": "^3.22.4",
    "@tiptap/extension-table-header": "^3.22.4",
    "@tiptap/extension-table-row": "^3.22.4",
    "@tiptap/extension-task-item": "^3.22.4",
    "@tiptap/extension-task-list": "^3.22.4",
    "@tiptap/extension-typography": "^3.22.4",
    "@tiptap/extension-youtube": "^3.22.4",
    "@tiptap/markdown": "^3.22.4",
    "@tiptap/react": "^3.22.4",
    "@tiptap/starter-kit": "^3.22.4",
    "@vitejs/plugin-react": "^5.0.4",
    "better-sqlite3": "^11.9.1",
    "call-bind-apply-helpers": "^1.0.2",
    "dompurify": "^3.4.0",
    "electron-vite": "^3.0.0",
    "isomorphic-git": "^1.37.5",
    "katex": "^0.16.45",
    "lucide-react": "^0.468.0",
    "marked": "^18.0.2",
    "mermaid": "^11.14.0",
    "otherone-agent": "^0.2.0",
    "pg": "^8.20.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "shiki": "^4.0.2",
    "turndown": "^7.2.4"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.3",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.10.2",
    "@types/pg": "^8.20.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/turndown": "^5.0.6",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "eslint": "^9.17.0",
    "typescript": "^5.7.2",
    "vite": "^6.0.5"
  },
  "overrides": {
    "otherone-agent": {
      "uuid": "11.1.0"
    }
  }
}
